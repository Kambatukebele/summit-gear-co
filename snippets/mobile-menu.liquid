<nav class="mobile-mobile-header__menus" role="navigation">
  <div class="mobile-header__close">
    <button class="mobile-header__close-btn">x</button>
  </div>
  <ul class="mobile-header__menu">
    {%- for item in (1..5) -%}
      <li class="mobile-header__list">
        <div class="mobile-header__list-level-1">
          <a href="#" class="mobile-header__list-level-1-link">Menu level 1</a>
          <span class="mobile-header__list-level-1-icon">+</span>
        </div>
        <div class="mobile-header__list-level-1-content">
          {%- for item in (1..5) -%}
            <div class="mobile-header__list-level-2">
              <a href="#" class="mobile-header__list-level-2-link">subMenu l2</a>
              <span class="mobile-header__list-level-2-icon">+</span>
            </div>

            <div class="mobile-header__list-level-2-content ">
              {%- for item in (1..5) -%}
                <a href="#" class="mobile-header__list-level-3-link">SubHomel3</a>
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      </li>
    {%- endfor -%}

    <li class="mobile-header__list-item">
      <a href="#" class="mobile-header__list-login">Login</a>
      <span class="mobile-header__list-slash">/</span>
      <a href="#" class="mobile-header__list-login">Register</a>
    </li>
  </ul>
</nav>

{% stylesheet %}
  .mobile-mobile-header__menus {
    position: absolute;
    top: 0px;
    left: 0px;
    width: 100vw;
    height: 100vh;
    z-index: 50;
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    gap: 16px;
    background-color: white;
  }
  .mobile-mobile-header__menus--animation {
    animation: myAnim 0.9s ease 0s 1 normal forwards;
  }
  @keyframes myAnim {
    0% {
      opacity: 0;
      transform: translateX(-100%);
    }

    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }
  .mobile-header__close {
    width: 90%;
    margin: 0px auto;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 8px 0px;
    max-height: 40px;
  }
  .mobile-header__close-btn {
    background-color: black;
    cursor: pointer;
    padding: 4px 12px;
    border: none;
    color: white;
    border-radius: 2px;
  }
  .mobile-header__menu {
    width: 90%;
    margin: 0px auto;
    display: flex;
    gap: 4px;
    flex-direction: column;
    overflow: scroll;
    background-color: white;
    height: calc(100vh - 56px);
  }
  .mobile-header__list {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: fit-content;
  }
  .mobile-header__list-level-1 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 52px;
  }
  .mobile-header__list-level-2 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 52px;
    padding-left: 8px;
  }

  .mobile-header__list-level-1-content {
    display: none;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-header__list-level-2-content {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding-left: 16px;
  }

  .mobile-header__list-level-1-link,
  .mobile-header__list-level-2-link,
  .mobile-header__list-level-3-link {
    display: block;
    text-decoration: none;
    color: black;
  }
  .mobile-header__list-level-3-link {
    height: 32px;
  }

  .header__hamburger .header__hamburger-icon,
  .header__whishlist-icon,
  .header__cart-icon,
  .header__search-icon,
  .header__account-icon {
    width: 24px;
    height: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .mobile-header__list-level-1-icon,
  .mobile-header__list-level-2-icon {
    font-size: 24px;
    display: block;
    cursor: pointer;
    font-weight: 700;
  }

  .mobile-header__list-item {
    margin-top: 8px;
  }
  .mobile-header__list-login {
    text-decoration: none;
    color: black;
    font-weight: 200;
  }

  @media (min-width: 1024px) {
    .mobile-mobile-header__menus {
      display: none;
    }
  }
{% endstylesheet %}

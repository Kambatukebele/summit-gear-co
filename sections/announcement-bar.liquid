<announcement-bar
  data-speed="{{ section.settings.announcement_bar_speed | times: 1000 }}"
  style="--background-color:{{ section.settings.announcement_bar_background_color }};--color:{{ section.settings.announcement_bar_text_color }};--text-transform:{{ section.settings.announcement_bar_text_transform }};"
  class="announcement-bar"
>
  <div class="announcement-bar__wrapper container">
    <div class="announcement-bar__content">
      <div class="announcement-bar__messages">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {%- case block.type -%}
              {%- when 'announcement' -%}
                <div class="announcement-bar__message {% unless forloop.first %}hidden{% endunless %}">
                  {{ block.settings.announcement_bar_message }}
                </div>
              {%- else -%}
            {%- endcase -%}
          {% endfor %}
        {% else %}
          {%- for item in (1..3) -%}
            <p class="announcement-bar__message {% unless forloop.first %}hidden{% endunless %}">
              Welcome to our store! Check out our latest products and offers.
            </p>
          {%- endfor -%}
        {% endif %}
      </div>
    </div>
  </div>
</announcement-bar>

<script src="{{ 'announcement.bar.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
  .announcement-bar {
    display: block;
    width: 100%;
    background: var(--background-color);
    height: 3.125rem;
  }
  .announcement-bar__wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100%;
  }
  .announcement-bar__content {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }
  .announcement-bar__messages {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .announcement-bar__message,
  .announcement-bar__message p {
    color: var(--color);
    font-size: 1rem;
    font-weight: bold;
    text-align: center;
    line-height: 1.5rem;
    text-transform: var(--text-transform);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "settings": [
    {
      "type": "header",
      "content": "Rotation speed (in seconds)",
      "info": "This section will rotate through the messages you add below. You can add up to 3 messages."
    },
    {
      "type": "range",
      "id": "announcement_bar_speed",
      "label": "Rotation speed (in seconds)",
      "default": 3,
      "min": 1,
      "max": 10,
      "step": 1
    },
    {
      "type": "header",
      "content": "t:sections.announcement_bar.settings.header_announcement_bar.content",
      "info": "t:sections.announcement_bar.settings.header_announcement_bar.info"
    },
    {
      "type": "color_background",
      "id": "announcement_bar_background_color",
      "label": "t:sections.announcement_bar.settings.announcement_bar_background_color.label",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "announcement_bar_text_color",
      "label": "t:sections.announcement_bar.settings.announcement_bar_text_color.label",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "announcement_bar_text_transform",
      "label": "Text transform",
      "default": "uppercase",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ]
    }
  ],
  "blocks": [
    {
      "name": "t:sections.announcement_bar.blocks.name",
      "type": "announcement",
      "limit": 3,
      "settings": [
        {
          "type": "richtext",
          "id": "announcement_bar_message",
          "label": "t:sections.announcement_bar.blocks.settings.announcement_message.label",
          "default": "<p>Free shipping on orders over $50!</p>",
          "info": "t:sections.announcement_bar.blocks.settings.announcement_message.info"
        }
      ]
    }
  ]
}
{% endschema %}
